generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}


model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  aiConnections       AIConnection[]
  conversations       Conversation[]
  orchestrationConfigs OrchestrationConfig[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AIConnection {
  id             String   @id @default(cuid())
  userId         String
  provider       String   // OPENAI | GEMINI | CLAUDE | MISTRAL
  encryptedApiKey String
  model          String
  isActive       Boolean  @default(true)
  label          String?  // Custom label, e.g. "My GPT-4 Key"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New Conversation")
  mode      String   @default("DIRECT") // DIRECT | ORCHESTRATED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  orchestrationConfig OrchestrationConfig?
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user | master | slave | system
  content        String
  provider       String?  // OPENAI | GEMINI etc.
  thinkingStep   Boolean  @default(false) // true for intermediate bot-to-bot messages
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model OrchestrationConfig {
  id             String   @id @default(cuid())
  userId         String
  conversationId String   @unique
  masterProvider String
  slaveProviders String   // JSON array of provider strings
  systemPrompt   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
